# Configuration EmailJS
# Copiez ce fichier en .env.local et remplacez les valeurs par vos propres identifiants
# Voir EMAILJS_SETUP.md pour les instructions dÃ©taillÃ©es

# Service ID EmailJS
# Obtenez-le depuis EmailJS Dashboard > Email Services
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_votre_service_id

# Template ID EmailJS
# Obtenez-le depuis EmailJS Dashboard > Email Templates
# Format: template_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_votre_template_id

# Public Key EmailJS
# Obtenez-le depuis EmailJS Dashboard > Account > General > API Keys
# Format: xxxxxxxxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=votre_public_key_ici

# URL du site (optionnel)
NEXT_PUBLIC_SITE_URL=https://rayeen.dev
